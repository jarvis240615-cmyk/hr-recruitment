{
  "version": 2,
  "builds": [
    {
      "src": "backend/main.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "50mb" }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "backend/main.py" },
    { "src": "/docs", "dest": "backend/main.py" },
    { "src": "/openapi.json", "dest": "backend/main.py" },
    { "src": "/(.*)", "dest": "backend/main.py" }
  ]
}
